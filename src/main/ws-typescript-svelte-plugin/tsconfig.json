{
  "compilerOptions": {
    "target": "ES2015",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["ES2015"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "types": ["tsc-ide-plugin/typescript", "node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
